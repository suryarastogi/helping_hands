# --- Postgres ---
POSTGRES_USER=helping_hands
POSTGRES_PASSWORD=changeme
POSTGRES_DB=helping_hands
POSTGRES_PORT=5432
DATABASE_URL=postgresql://helping_hands:changeme@postgres:5432/helping_hands

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
# Result backend: use Redis or Postgres (db+ prefix).
# CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_RESULT_BACKEND=db+postgresql://helping_hands:changeme@postgres:5432/helping_hands

# --- Server ---
SERVER_PORT=8000

# --- Flower ---
FLOWER_PORT=5555

# --- MCP Server ---
MCP_PORT=8080

# --- GitHub ---
GITHUB_TOKEN=ghp_your_personal_access_token_here
GH_TOKEN=

# --- helping_hands ---
# Optional: override the default owner/repo shown in the frontend form.
HELPING_HANDS_DEFAULT_REPO=
HELPING_HANDS_MODEL=default
HELPING_HANDS_VERBOSE=false
# Optional: directory for temporary repo clones. Defaults to the OS temp dir
# (/var/folders/... on macOS). Set this to a known path so clones are easy to
# locate and clean up. The directory is created automatically if it doesn't exist.
# Clones are deleted automatically after each run.
# Example: HELPING_HANDS_REPO_TMP=/tmp/helping_hands
HELPING_HANDS_REPO_TMP=
# Optional: for codexcli/claudecodecli, strip provider API key env vars from
# subprocess runs so local CLI session auth (e.g., codex login/claude auth) is used.
HELPING_HANDS_USE_NATIVE_CLI_AUTH=0

# --- Per-backend native CLI auth overrides ---
# When set, overrides the global HELPING_HANDS_USE_NATIVE_CLI_AUTH for that backend.
HELPING_HANDS_CODEX_USE_NATIVE_CLI_AUTH=0
HELPING_HANDS_CLAUDE_USE_NATIVE_CLI_AUTH=0
HELPING_HANDS_DEVIN_USE_NATIVE_CLI_AUTH=0

# --- Backend enabled flags ---
# Only backends set to 1 will appear in the frontend dropdown.
# If none are set, all backends are shown (backwards-compatible default).
# HELPING_HANDS_E2E_ENABLED=0
# HELPING_HANDS_LANGGRAPH_ENABLED=0
# HELPING_HANDS_ATOMIC_ENABLED=0
# HELPING_HANDS_CODEXCLI_ENABLED=1
# HELPING_HANDS_CLAUDECODECLI_ENABLED=1
# HELPING_HANDS_DOCKER_SANDBOX_CLAUDE_ENABLED=0
# HELPING_HANDS_GOOSE_ENABLED=0
# HELPING_HANDS_GEMINICLI_ENABLED=0
# HELPING_HANDS_OPENCODECLI_ENABLED=0
# HELPING_HANDS_DEVINCLI_ENABLED=0

# --- AI provider credentials (used by hand backends) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Devin CLI auth key (used by devincli backend).
DEVIN_API_KEY=
# Gemini CLI auth key (used by geminicli backend).
GEMINI_API_KEY=
# Optional API key for Ollama's OpenAI-compatible endpoint.
OLLAMA_API_KEY=
# Base URL used by provider wrappers (OpenAI-compatible Ollama endpoint).
OLLAMA_BASE_URL=http://localhost:11434/v1
# Host used by Goose when provider is ollama.
OLLAMA_HOST=http://localhost:11434

# --- CLI hand command overrides ---
# Default Claude command is `claude -p`; if missing and npx exists, runtime
# auto-retries with `npx -y @anthropic-ai/claude-code`.
HELPING_HANDS_CLAUDE_CLI_CMD=claude -p
HELPING_HANDS_CODEX_CLI_CMD=codex
HELPING_HANDS_GOOSE_CLI_CMD=goose run --with-builtin developer --text
HELPING_HANDS_GEMINI_CLI_CMD=gemini -p
HELPING_HANDS_DEVIN_CLI_CMD=devin -p
# Default model for devincli backend. Defaults to claude-opus-4-6.
# Examples: claude-opus-4-6, openai/gpt-5.4, opus
HELPING_HANDS_DEVIN_MODEL=

# --- CLI subprocess stream/timeout controls ---
# Poll interval while waiting for CLI stdout.
HELPING_HANDS_CLI_IO_POLL_SECONDS=2
# Emit a heartbeat line when no CLI output has been seen for this many seconds.
HELPING_HANDS_CLI_HEARTBEAT_SECONDS=20
# Terminate a silent CLI process after this many seconds without output.
HELPING_HANDS_CLI_IDLE_TIMEOUT_SECONDS=900
# Shorter idle timeout for CI fix subprocess invocations (default 300s / 5 min).
# CI fixes are typically quick (formatting, lint), so no need for the full 15 min.
HELPING_HANDS_CLI_CI_FIX_IDLE_TIMEOUT_SECONDS=300
# Maximum number of CI fix retry attempts (default 3).
HELPING_HANDS_CI_MAX_RETRIES=3

# --- Claude Code CLI safety/container controls ---
# Non-interactive default for non-root runs. Automatically ignored/retried
# without the flag when Claude rejects root/sudo usage.
HELPING_HANDS_CLAUDE_DANGEROUS_SKIP_PERMISSIONS=1
# Optional: run Claude command inside Docker (disabled by default).
HELPING_HANDS_CLAUDE_CONTAINER=0
# Required only when HELPING_HANDS_CLAUDE_CONTAINER=1.
HELPING_HANDS_CLAUDE_CONTAINER_IMAGE=

# --- Codex CLI safety/container controls ---
# Optional override. Leave empty to auto-select:
# - host runtime: workspace-write
# - container runtime: danger-full-access (avoids landlock failures)
HELPING_HANDS_CODEX_SANDBOX_MODE=
# Defaults to skipping codex trusted-directory git repo checks for automation.
HELPING_HANDS_CODEX_SKIP_GIT_REPO_CHECK=1
# Optional: run codex command inside Docker (disabled by default).
HELPING_HANDS_CODEX_CONTAINER=0
# Required only when HELPING_HANDS_CODEX_CONTAINER=1.
HELPING_HANDS_CODEX_CONTAINER_IMAGE=
